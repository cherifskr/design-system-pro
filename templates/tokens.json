{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Exemple de tokens design system au format W3C DTCG. Point de départ pour un nouveau DS. À adapter à ton projet.",
  "color": {
    "palette": {
      "$description": "Primitives — palette brute, jamais utilisée directement dans l'UI",
      "black": { "$type": "color", "$value": "#0A0A0A" },
      "white": { "$type": "color", "$value": "#FFFFFF" },
      "neutral": {
        "50":  { "$type": "color", "$value": "#FAFAFA" },
        "100": { "$type": "color", "$value": "#F5F5F5" },
        "200": { "$type": "color", "$value": "#E5E5E5" },
        "300": { "$type": "color", "$value": "#D4D4D4" },
        "400": { "$type": "color", "$value": "#A3A3A3" },
        "500": { "$type": "color", "$value": "#737373" },
        "600": { "$type": "color", "$value": "#525252" },
        "700": { "$type": "color", "$value": "#404040" },
        "800": { "$type": "color", "$value": "#262626" },
        "900": { "$type": "color", "$value": "#171717" }
      },
      "blue": {
        "500": { "$type": "color", "$value": "#3B82F6" },
        "600": { "$type": "color", "$value": "#2563EB" },
        "700": { "$type": "color", "$value": "#1D4ED8" }
      },
      "red": {
        "500": { "$type": "color", "$value": "#EF4444" },
        "600": { "$type": "color", "$value": "#DC2626" }
      },
      "green": {
        "500": { "$type": "color", "$value": "#22C55E" },
        "600": { "$type": "color", "$value": "#16A34A" }
      },
      "amber": {
        "500": { "$type": "color", "$value": "#F59E0B" }
      }
    },
    "semantic": {
      "$description": "Sémantiques — rôles utilisés dans l'UI, référencent la palette",
      "background":        { "$type": "color", "$value": "{color.palette.white}" },
      "foreground":        { "$type": "color", "$value": "{color.palette.black}" },
      "muted":             { "$type": "color", "$value": "{color.palette.neutral.500}" },
      "card":              { "$type": "color", "$value": "{color.palette.white}" },
      "border":            { "$type": "color", "$value": "{color.palette.neutral.200}" },
      "primary":           { "$type": "color", "$value": "{color.palette.black}" },
      "primary-hover":     { "$type": "color", "$value": "{color.palette.neutral.800}" },
      "primary-foreground":{ "$type": "color", "$value": "{color.palette.white}" },
      "destructive":       { "$type": "color", "$value": "{color.palette.red.500}" },
      "destructive-hover": { "$type": "color", "$value": "{color.palette.red.600}" },
      "success":           { "$type": "color", "$value": "{color.palette.green.500}" },
      "warning":           { "$type": "color", "$value": "{color.palette.amber.500}" },
      "focus":             { "$type": "color", "$value": "{color.palette.blue.500}" }
    }
  },
  "spacing": {
    "$description": "Échelle base 4px. Multiples pairs + demi-valeurs utiles",
    "0":   { "$type": "dimension", "$value": "0px" },
    "0-5": { "$type": "dimension", "$value": "2px" },
    "1":   { "$type": "dimension", "$value": "4px" },
    "2":   { "$type": "dimension", "$value": "8px" },
    "3":   { "$type": "dimension", "$value": "12px" },
    "4":   { "$type": "dimension", "$value": "16px" },
    "5":   { "$type": "dimension", "$value": "20px" },
    "6":   { "$type": "dimension", "$value": "24px" },
    "8":   { "$type": "dimension", "$value": "32px" },
    "10":  { "$type": "dimension", "$value": "40px" },
    "12":  { "$type": "dimension", "$value": "48px" },
    "16":  { "$type": "dimension", "$value": "64px" },
    "20":  { "$type": "dimension", "$value": "80px" },
    "24":  { "$type": "dimension", "$value": "96px" }
  },
  "radius": {
    "none": { "$type": "dimension", "$value": "0px" },
    "sm":   { "$type": "dimension", "$value": "4px" },
    "md":   { "$type": "dimension", "$value": "8px" },
    "lg":   { "$type": "dimension", "$value": "12px" },
    "xl":   { "$type": "dimension", "$value": "16px" },
    "2xl":  { "$type": "dimension", "$value": "24px" },
    "full": { "$type": "dimension", "$value": "9999px" }
  },
  "font": {
    "family": {
      "sans":  { "$type": "fontFamily", "$value": ["Inter", "system-ui", "sans-serif"] },
      "mono":  { "$type": "fontFamily", "$value": ["JetBrains Mono", "ui-monospace", "monospace"] },
      "serif": { "$type": "fontFamily", "$value": ["Georgia", "serif"] }
    },
    "weight": {
      "regular":  { "$type": "fontWeight", "$value": 400 },
      "medium":   { "$type": "fontWeight", "$value": 500 },
      "semibold": { "$type": "fontWeight", "$value": 600 },
      "bold":     { "$type": "fontWeight", "$value": 700 }
    },
    "size": {
      "xs":   { "$type": "dimension", "$value": "12px" },
      "sm":   { "$type": "dimension", "$value": "14px" },
      "base": { "$type": "dimension", "$value": "16px" },
      "lg":   { "$type": "dimension", "$value": "18px" },
      "xl":   { "$type": "dimension", "$value": "20px" },
      "2xl":  { "$type": "dimension", "$value": "24px" },
      "3xl":  { "$type": "dimension", "$value": "32px" },
      "4xl":  { "$type": "dimension", "$value": "40px" },
      "5xl":  { "$type": "dimension", "$value": "48px" }
    }
  },
  "typography": {
    "$description": "Styles typographiques composés (tokens composites W3C)",
    "body": {
      "$type": "typography",
      "$value": {
        "fontFamily":    "{font.family.sans}",
        "fontSize":      "{font.size.base}",
        "fontWeight":    "{font.weight.regular}",
        "lineHeight":    1.6,
        "letterSpacing": "0"
      }
    },
    "heading-lg": {
      "$type": "typography",
      "$value": {
        "fontFamily":    "{font.family.sans}",
        "fontSize":      "{font.size.3xl}",
        "fontWeight":    "{font.weight.bold}",
        "lineHeight":    1.2,
        "letterSpacing": "-0.02em"
      }
    }
  },
  "shadow": {
    "sm": {
      "$type": "shadow",
      "$value": { "color": "#0000001a", "offsetX": "0px", "offsetY": "1px", "blur": "2px", "spread": "0px" }
    },
    "md": {
      "$type": "shadow",
      "$value": { "color": "#00000020", "offsetX": "0px", "offsetY": "4px", "blur": "12px", "spread": "0px" }
    },
    "lg": {
      "$type": "shadow",
      "$value": { "color": "#00000026", "offsetX": "0px", "offsetY": "8px", "blur": "32px", "spread": "0px" }
    },
    "xl": {
      "$type": "shadow",
      "$value": { "color": "#00000033", "offsetX": "0px", "offsetY": "16px", "blur": "48px", "spread": "0px" }
    }
  },
  "motion": {
    "duration": {
      "instant": { "$type": "duration", "$value": "0ms" },
      "short":   { "$type": "duration", "$value": "150ms" },
      "medium":  { "$type": "duration", "$value": "250ms" },
      "long":    { "$type": "duration", "$value": "400ms" }
    },
    "easing": {
      "linear":   { "$type": "cubicBezier", "$value": [0, 0, 1, 1] },
      "ease-out": { "$type": "cubicBezier", "$value": [0, 0, 0.2, 1] },
      "ease-in":  { "$type": "cubicBezier", "$value": [0.4, 0, 1, 1] },
      "smooth":   { "$type": "cubicBezier", "$value": [0.16, 1, 0.3, 1] }
    }
  },
  "breakpoint": {
    "$description": "Points de rupture responsive (dimension min-width)",
    "sm": { "$type": "dimension", "$value": "640px" },
    "md": { "$type": "dimension", "$value": "768px" },
    "lg": { "$type": "dimension", "$value": "1024px" },
    "xl": { "$type": "dimension", "$value": "1280px" }
  }
}
